{
    "name": "bohn-media/contao-vite-bundle",
    "description": "Contao 5 wrapper around pentatrion/vite-bundle. Registers the upstream bundle in Contao Manager Edition so its Twig functions are available out of the box.",
    "type": "contao-bundle",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "contao/core-bundle": "^5.0",
        "contao/manager-plugin": "^2.0",
        "pentatrion/vite-bundle": "^8.0",
        "symfony/http-kernel": "^6.4 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "BohnMedia\\ContaoViteBundle\\": "src/"
        }
    },
    "extra": {
        "contao-manager-plugin": "BohnMedia\\ContaoViteBundle\\ContaoManager\\Plugin"
    },
    "require-dev": {
        "phpstan/phpstan": "*",
        "phpstan/extension-installer": "*",
        "phpstan/phpstan-symfony": "*"
    },
    "config": {
        "allow-plugins": {
            "contao-components/installer": true,
            "contao/manager-plugin": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    }
}
